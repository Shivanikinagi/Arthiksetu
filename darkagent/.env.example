# DarkAgent Environment Variables
# Copy this to .env and fill in your values

# Deployer private key (DO NOT COMMIT REAL KEYS)
PRIVATE_KEY=your_deployer_private_key_here

# Base Sepolia RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Basescan API Key for contract verification
BASESCAN_API_KEY=your_basescan_api_key_here

# ENS Configuration (optional - for ENS integration)
ENS_REGISTRY_ADDRESS=
ENS_RESOLVER_ADDRESS=

# BitGo Configuration (optional - for spending controls)
BITGO_ACCESS_TOKEN=your_bitgo_access_token_here
BITGO_WALLET_ID=your_bitgo_wallet_id_here
BITGO_PASSPHRASE=your_bitgo_passphrase_here
BITGO_ENV=test

# Contract Addresses (populated after deployment)
DARKAGENT_CONTRACT=
AGENT_REGISTRY_CONTRACT=
SIMULATION_ENGINE_CONTRACT=

# Demo Agent Addresses
TRADING_AGENT_ADDRESS=
DATA_AGENT_ADDRESS=
TRADING_AGENT_PRIVATE_KEY=your_trading_agent_key
DATA_AGENT_PRIVATE_KEY=your_data_agent_key
